      "/dcs/large/u5573765/tools/cvc5-Linux-x86_64-static/bin"
    ]
  },

  "benchmark_suite": {
    "name": "suite_9k",
    "path": "/dcs/large/u5573765/data/benchmarks/suite_9k",
    "total_instances": 9000,
    "QF_BV": 3000,
    "QF_LIA": 3000,
    "QF_NRA": 3000
  },

  "cross_validation": {
    "method": "5-fold GroupKFold (family-aware)",
    "folds_file": "shared_folds_k5.json",
    "folds_path": "/dcs/23/u5573765/cs351/eval-sibyl/shared_folds_k5.json",
    "shared_with": ["Grackle", "MachSMT", "SMTgazer", "Medley"],
    "note": "Families are never split across folds — test families are entirely unseen during training"
  },

  "sibyl_training_params": {
    "portfolio_id": 7,
    "n_configs": 6,
    "config_order": [
      "z3_baseline_default",
      "z3_baseline_qflia_case_split",
      "z3_baseline_qfbv_sat_euf_sat",
      "cvc5_baseline_default",
      "cvc5_qfnra_05_nl_cov",
      "cvc5_qfnra_08_decision_just"
    ],
    "epochs": 20,
    "time_steps": 2,
    "edge_sets": ["AST_Back", "AST_Data"],
    "pool_type": "attention",
    "data_weight": "best",
    "mode": "cat",
    "no_jump": true,
    "dropout": 0,
    "max_graph_nodes": 500000,
    "solver_timeout_per_instance_s": 60,
    "inference_workers": 12
  },

  "sbatch_flags": {
    "smoke_test": {
      "partition": "gecko,falcon",
      "cpus_per_task": 4,
      "gres": "gpu:1",
      "wall_time": "00:30:00",
      "mail_type": "END,FAIL"
    },
    "training": {
      "partition": "gecko,falcon",
      "cpus_per_task": 12,
      "gres": "gpu:1",
      "wall_time": "2-00:00:00",
      "mail_type": "END,FAIL,TIME_LIMIT_80"
    }
  },

  "cli_invocations": {
    "smoke_test": {
      "command": "python3 -u smoke_test_sibyl.py",
      "working_directory": "/dcs/23/u5573765/cs351/eval-sibyl",
      "description": "Samples 200 QF_LIA benchmarks, trains 2 epochs, infers on 20 held-out, PASS if >=75% valid"
    },
    "training": {
      "command": "python3 -u sibyl_portfolio_trainer.py --stage train --epochs 20 --output-dir sibyl_results",
      "working_directory": "/dcs/23/u5573765/cs351/eval-sibyl",
      "description": "5-fold GroupKFold CV x 3 logics, 20 epochs/fold, using upstream smtTrainer.py"
    },
    "merge": {
      "command": "python3 -u sibyl_portfolio_trainer.py --stage merge --output-dir sibyl_results",
      "working_directory": "/dcs/23/u5573765/cs351/eval-sibyl",
      "description": "Merge per-logic decisions CSVs into combined decisions_all.csv"
    },
    "evaluation": {
      "command": "python3 -u sibyl_evaluate_decisions.py --output-dir sibyl_results",
      "working_directory": "/dcs/23/u5573765/cs351/eval-sibyl",
      "description": "Evaluate Sibyl vs VBS/SBS/Random baselines, write decisions to DB"
    },
    "submit_command": "sbatch /dcs/23/u5573765/cs351/eval-sibyl/smoke_test_sibyl.sbatch"
  },

  "runs": {
