      "sibyl_results/decisions_QF_BV.csv",
      "sibyl_results/decisions_QF_LIA.csv",
      "sibyl_results/decisions_QF_NRA.csv"
    ],
    "merged_decisions": "sibyl_results/decisions_all.csv",
    "models": "sibyl_results/models/sibyl_<LOGIC>_fold<N>.pt",
